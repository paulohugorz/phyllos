  "_calculo_blends": {
    "descricao": "Para peças com múltiplas fibras, calcular o indicador ponderado pela fração mássica.",
    "formula": "indicador_total = Σ (fracao_fibra_i × indicador_fibra_i)",
    "exemplo": {
      "composicao": { "algodao_convencional": 0.95, "elastano_spandex": 0.05 },
      "co2eq_calculado": "0.95 × 5.9 + 0.05 × 26.0 = 5.605 + 1.3 = 6.905 kgCO2eq/kg"
    }
  },
